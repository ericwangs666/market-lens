#!/usr/bin/env sh
set -e

BASE_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
PROPERTIES_FILE="$WRAPPER_DIR/maven-wrapper.properties"
MAVEN_VERSION="3.9.9"
MAVEN_DIR="$WRAPPER_DIR/apache-maven-$MAVEN_VERSION"
MAVEN_CMD="$MAVEN_DIR/bin/mvn"
MAVEN_ZIP="$WRAPPER_DIR/apache-maven-$MAVEN_VERSION-bin.zip"
DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/$MAVEN_VERSION/apache-maven-$MAVEN_VERSION-bin.zip"

if [ -f "$PROPERTIES_FILE" ]; then
  PROPERTY_URL=$(sed -n 's/^distributionUrl=//p' "$PROPERTIES_FILE" | tail -n 1)
  if [ -n "$PROPERTY_URL" ]; then
    DOWNLOAD_URL="$PROPERTY_URL"
  fi
fi

if [ ! -x "$MAVEN_CMD" ]; then
  echo "Maven $MAVEN_VERSION was not found locally. Downloading..."
  mkdir -p "$WRAPPER_DIR"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$DOWNLOAD_URL" -o "$MAVEN_ZIP"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$DOWNLOAD_URL" -O "$MAVEN_ZIP"
  else
    echo "curl or wget is required to download Maven." >&2
    exit 1
  fi
  unzip -q "$MAVEN_ZIP" -d "$WRAPPER_DIR"
fi

exec "$MAVEN_CMD" "$@"
